{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "friends": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "trips": {
      "$tripId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
